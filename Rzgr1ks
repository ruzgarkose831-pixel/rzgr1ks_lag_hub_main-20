Instance.new("UIListLayout", scroll).Padding = UDim.new(0, 5)

local function makeTog(txt, cb)
    local b = Instance.new("TextButton", scroll)
    b.Size = UDim2.new(0.95, 0, 0, 32); b.BackgroundColor3 = Color3.fromRGB(45, 35, 55); b.Text = txt; b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.GothamBold; b.TextSize = 10
    Instance.new("UICorner", b)
    local act = false
    b.MouseButton1Click:Connect(function() act = not act; b.BackgroundColor3 = act and pa or Color3.fromRGB(45, 35, 55); cb(act) end)
end

makeTog("SPEED (55)", function(v) speed55 = v end)
