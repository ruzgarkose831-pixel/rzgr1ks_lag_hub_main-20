local function drag(obj)
    local d, i, s, p
    obj.InputBegan:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then d = true; s = inp.Position; p = obj.Position end end)
    obj.InputChanged:Connect(function(inp) if inp == i and d then local delta = inp.Position - s; obj.Position = UDim2.new(p.X.Scale, p.X.Offset + delta.X, p.Y.Scale, p.Y.Offset + delta.Y) end end)
    obj.InputChanged:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch then i = inp end end)
end
drag(main)

local scroll = Instance.new("ScrollingFrame", main)
